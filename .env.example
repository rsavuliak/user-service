# Base64-encoded HMAC key (same value the Auth Service uses). Must decode to >= 32 bytes for HS256.
JWT_SECRET=replace-me-with-base64-of-at-least-32-bytes

# Shared secret for server-to-server calls from the Auth Service. Min 32 characters.
INTERNAL_API_KEY=replace-me-with-32-plus-char-random-string

# Comma-separated list (only one entry also fine).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Local Postgres credentials (defaults match docker-compose.yml).
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Optional. Defaults to jdbc:postgresql://localhost:5433/user_service for local dev.
# On the droplet (compose network) set to jdbc:postgresql://postgres:5432/user_service.
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/user_service

# Optional. Defaults to 8081.
# SERVER_PORT=8081
